PORT=3000
NODE_ENV=production

# From Aiven Console → Your Service → Overview tab
DB_HOST=your-service.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASSWORD=your_password_here
DB_NAME=github_analyzer
DB_SSL=true

# Optional but recommended (raises GitHub rate limit 60 → 5000/hr)
# Create at github.com/settings/tokens 
GITHUB_TOKEN=ghp_your_token_here